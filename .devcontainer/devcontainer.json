// .devcontainer/devcontainer.json
{
    "name": "TP2 Trabalho 2 190042656",
    "dockerComposeFile": "docker-compose.yml",
    "service": "dev",
    "workspaceFolder": "/workspace",
    "shutdownAction": "stopCompose",
    "remoteUser": "root",
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd", // I enjoy proper documentation while coding.
                "ms-vscode.cpptools",
                // "twxs.cmake",  // cmake-tools instead
                "yzhang.markdown-all-in-one", // Great to read my markdown
                "eamodio.gitlens",
                "ms-vscode.cmake-tools"
            ],
            "settings": {
                // This disables the MS IntelliSense so it doesn't conflict with clangd
                "C_Cpp.intelliSenseEngine": "disabled",
                "clangd.path": "/usr/bin/clangd",
                "clangd.fallbackFlags": [
                    "-std=c++20"
                ],
                "clangd.arguments": [
                    "--fallback-style=file"
                ],
                "editor.tabSize": 2,
                "editor.insertSpaces": true,
                "editor.formatOnSave": true,
                "editor.comments.insertSpace": true,
                "files.insertFinalNewline": true,
                "files.trimTrailingWhitespace": true,
                "[cpp]": {
                    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
                    "editor.formatOnSave": true
                }
            }
        }
    }
}
